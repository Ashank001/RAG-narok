PORT=3000
MONGO_URI=mongodb://localhost:27017/api-gateway
REDIS_HOST=localhost
REDIS_PORT=6379

# Comma-separated list of origins allowed by CORS.
# Add your production domain here before deploying.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional GitHub PAT for verifying private repos during ingestion validation.
# If omitted, private repos are rejected with 403.
GITHUB_TOKEN=
